# ═══════════════════════════════════════════
# TYCOON CLAW — Configuração de Ambiente
# Copie para .env e preencha os valores
# ═══════════════════════════════════════════

# ─── LLM PROVIDERS ──────────────────────────
# Escolha um: openai, anthropic, ollama
DEFAULT_LLM_PROVIDER=openai

# OpenAI (ou OpenRouter usando mesma interface)
OPENAI_API_KEY=sk-...
# Para OpenRouter, adicione também:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local — sem chave necessária)
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# ─── SERVIDOR ───────────────────────────────
PORT=3000
OPENCLAW_PORT=18789

# ─── OPCIONAL ───────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=

# ClickUp
CLICKUP_TOKEN=
CLICKUP_LIST_ID=
